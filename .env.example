# Contoh variabel tambahan (gabungkan dengan .env Anda).

# --- Email status pesanan (Gmail / SMTP) ---
# Set true setelah MAIL_* berikut diisi dan diuji (php artisan tinker: Mail::raw(...))
ORDER_STATUS_MAIL_ENABLED=false
ORDER_STATUS_MAIL_BCC_ADMIN=false
ORDER_STATUS_MAIL_ADMIN_ADDRESS=

# Contoh Gmail (App Password di akun Google):
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=your-email@gmail.com
# MAIL_FROM_NAME="Nama Toko"
